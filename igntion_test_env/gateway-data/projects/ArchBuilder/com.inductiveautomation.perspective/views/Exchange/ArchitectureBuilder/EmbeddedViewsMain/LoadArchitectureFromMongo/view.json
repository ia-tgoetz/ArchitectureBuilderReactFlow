        "config": {
          "script": "\t# Defines the type of Ignition resource being accessed (e.g., a Perspective View, Scripting Package, )\n\tresourceType\u003d\"view\"\n\t# Specific name of the current resource\n\tresourceName\u003dself.view.id.split(\"/\")[-1]\n\t# Custom logger name to define purpose of log\n\tloggerName\u003d\"LoadMongoData\"\n\tfullLoggerName\u003d\u0027exchange.archBuilder.{resourceType}.{resourceName}.{loggerName}\u0027.format(resourceType\u003dresourceType,resourceName\u003dresourceName,loggerName\u003dloggerName)\n\tlogger\u003dsystem.util.getLogger(fullLoggerName)\n\n\n\tdef getConnectorState(name):\n\t\tallow\u003dTrue\n\t\tfor connector in self.session.custom.admin.mongoAccess:\n\t\t\tif name\u003d\u003dconnector[\u0027name\u0027]:\n\t\t\t\tallow\u003dconnector[\u0027allow\u0027]\n\t\t\t\tbreak\n\t\treturn allow\n\t\n\tself.custom.date\u003dsystem.date.now()\n\tconnectors\u003dsystem.mongodb.listConnectorInfo()\n\tsystem.perspective.print(connectors)\n\tconnectorDrop\u003d[]\n\tfor connector in connectors:\n\t\tconnectorDrop.append({\n\t\t  \"value\": connector[\u0027name\u0027],\n\t\t  \"label\": connector[\u0027name\u0027]\n\t\t})\n\n\t\t\n\tself.getChild(\"root\").getChild(\"Connectors\").getChild(\"Connectors\").props.options\u003dconnectorDrop\n\tif len(connectorDrop)\u003e0:\n\t\tfirstCollection\u003dconnectorDrop[-1][\u0027value\u0027]\n\t\tself.getChild(\"root\").getChild(\"Connectors\").getChild(\"Connectors\").props.value\u003dfirstCollection\n\t\n\tself.getChild(\"root\").getChild(\"File\").getChild(\"File\").props.value\u003dNone\n\tself.getChild(\"root\").getChild(\"Collections\").getChild(\"Collectios\").props.value\u003dNone"
        },
        "scope": "G",
        "type": "script"
      }
    }
