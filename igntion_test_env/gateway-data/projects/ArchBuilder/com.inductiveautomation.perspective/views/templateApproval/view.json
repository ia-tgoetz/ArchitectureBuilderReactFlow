{
  "custom": {},
  "params": {
    "name": ""
  },
  "propConfig": {
    "params.name": {
      "paramDirection": "inout",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 42
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "TextField"
        },
        "position": {
          "basis": "150px",
          "grow": 1
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "bidirectional": true,
                "path": "view.params.name"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "placeholder": "Enter Hostname..."
        },
        "type": "ia.input.text-field"
      },
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"remove\", {\"name\": self.view.params.name})"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "Icon"
        },
        "position": {
          "basis": "30px"
        },
        "props": {
          "path": "material/remove_circle_outline",
          "style": {
            "cursor": "pointer"
          }
        },
        "type": "ia.display.icon"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "style": {
        "margin": "4px"
      }
    },
    "type": "ia.container.flex"
  }
}